{
  "name": "notter",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:https": "next dev --experimental-https",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "knip": "knip",
    "pake": "npx --yes pake-cli@latest http://localhost:3000/?notter_desktop=1 --name Notter --app-version 0.5.0 --icon ./public/image/icon.png",
    "pake:windows": "npm run pake -- --targets msi",
    "pake:linux": "npm run pake -- --targets deb,appimage,rpm",
    "pake:macos": "npm run pake -- --targets dmg --multi-arch",
    "pake:all": "npm run pake:windows && npm run pake:linux && npm run pake:macos"
  },
